            <div style={{ ...heroStyles.badge, background: "rgba(0,0,0,0.05)", border: "1px solid rgba(0,0,0,0.1)", borderRadius: "20px", color: "#1A1A2E" }} className="animate-fade-in">
              <span style={{ fontSize: 16 }}>🐶</span>
              <span style={{ opacity: 0.9, fontWeight: 500 }}>Trusted by 15+ Barangays</span>
            </div>

            <h1 style={{ ...heroStyles.heading, fontWeight: 700, color: "#1A1A2E" }} className="animate-fade-in stagger-1">
              Protect, Register &<br />
              <span style={{ color: "#F59E0B" }}>Find Your Pets</span><br />
              in the Community
            </h1>

            <p style={{ ...heroStyles.subtext, color: "#6B7280" }} className="animate-fade-in stagger-2">
              AlagaLahat is the Philippines&apos; community-<br/>powered pet safety network. Register pets, get<br/>QR protection, and connect with neighbors who<br/>care.

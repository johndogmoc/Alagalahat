              <Button size="lg" asChild href="/lost-pets/report" style={{ background: "transparent", borderColor: "rgba(0,0,0,0.2)", color: "#1A1A2E", fontWeight: 600, padding: "0 28px", borderRadius: "8px", border: "1px solid rgba(0,0,0,0.2)" }}>

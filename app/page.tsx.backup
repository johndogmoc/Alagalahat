            Protect your pets, support your community, and help reunite lost animals with their families.
          </p>
          <div style={{ display: "flex", justifyContent: "center", gap: 16, flexWrap: "wrap" }}>
            <Button variant="primary" size="lg" asChild href="/register" style={{ background: "#3B82F6", color: "#FFFFFF" }}>
              <span style={{ display: "flex", alignItems: "center", gap: 8, fontWeight: 700 }}>
                Get Started — It&apos;s Free <IconChevronRight size={16} />
              </span>
            </Button>
            <Button variant="outline" size="lg" asChild href="/lost-pets" style={{ borderColor: "rgba(0,0,0,0.2)", color: "#1A1A2E" }}>
              <span>Browse Lost Pets</span>
            </Button>
          </div>
        </div>
      </section>

      {/* ============= FOOTER ============= */}
      <footer style={{
        padding: "48px 0 24px",
        background: "#1c2536",
        color: "rgba(255,255,255,0.7)"
      }}>
        <div className="container">
          <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(200px, 1fr))", gap: 40, marginBottom: 40 }}>
            {/* Brand */}
            <div>
              <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 16 }}>
                <div style={{ width: 36, height: 36, borderRadius: 8, background: "rgba(255,255,255,0.15)", display: "flex", alignItems: "center", justifyContent: "center", color: "#fff" }}>
                  <IconPaw size={18} />
                </div>
                <span style={{ fontWeight: 700, fontSize: 18, color: "#fff" }}>AlagaLahat</span>
              </div>
              <p style={{ fontSize: 13, lineHeight: 1.7, margin: 0, maxWidth: 280 }}>
                The Philippines&apos; community-powered pet safety network. Protecting pets, serving barangays.
              </p>
            </div>

            {/* Quick Links */}
            <div>
              <h4 style={{ fontSize: 14, fontWeight: 700, color: "#fff", margin: "0 0 16px", textTransform: "uppercase", letterSpacing: "0.05em" }}>Quick Links</h4>
              <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
                {[
                  { href: "/lost-pets", label: "Lost Pet Board" },
                  { href: "/care-guide", label: "Care Guide" },
                  { href: "/search", label: "Search Pets" },
                  { href: "/register", label: "Sign Up" }
                ].map((link) => (
                  <Link key={link.href} href={link.href} style={{ fontSize: 14, color: "rgba(255,255,255,0.7)", textDecoration: "none", transition: "color 200ms" }}>
                    {link.label}
                  </Link>
                ))}
              </div>
            </div>

            {/* Resources */}
            <div>
              <h4 style={{ fontSize: 14, fontWeight: 700, color: "#fff", margin: "0 0 16px", textTransform: "uppercase", letterSpacing: "0.05em" }}>Resources</h4>
              <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
                {[
                  { href: "/help", label: "Help & Support" },
                  { href: "#", label: "Barangay Partners" },
                  { href: "#", label: "Privacy Policy" },
                  { href: "#", label: "Terms of Service" }
                ].map((link) => (
                  <Link key={link.label} href={link.href} style={{ fontSize: 14, color: "rgba(255,255,255,0.7)", textDecoration: "none" }}>
                    {link.label}
                  </Link>
                ))}
              </div>
            </div>

            {/* Contact */}
            <div>
              <h4 style={{ fontSize: 14, fontWeight: 700, color: "#fff", margin: "0 0 16px", textTransform: "uppercase", letterSpacing: "0.05em" }}>Contact</h4>
              <div style={{ display: "flex", flexDirection: "column", gap: 10, fontSize: 14 }}>
                <p style={{ margin: 0 }}> support@alagalahat.ph</p>
                <p style={{ margin: 0 }}> (02) 8123-4567</p>
                <p style={{ margin: 0 }}> Barangay Hall, Your City</p>
              </div>
            </div>
          </div>

          {/* Bottom bar */}
          <div style={{ borderTop: "1px solid rgba(255,255,255,0.1)", paddingTop: 24, display: "flex", justifyContent: "space-between", alignItems: "center", flexWrap: "wrap", gap: 12 }}>
            <p style={{ margin: 0, fontSize: 13 }}>
               {new Date().getFullYear()} AlagaLahat. All rights reserved.
            </p>
            <p style={{ margin: 0, fontSize: 12, opacity: 0.5 }}>
              Made with ️ for Filipino pet owners
            </p>
          </div>
        </div>
      </footer>

      {/* ============= RESPONSIVE ============= */}
      <style>{`
        @media (max-width: 768px) {
          .hero-content { flex-direction: column !important; text-align: center; gap: 40px !important; }
          .hero-visual { display: block !important; margin: 0 auto; transform: scale(0.9); }
          .hero-text { max-width: 100% !important; }
          .hero-cta { justify-content: center !important; }
          .hero-trust { justify-content: center !important; }
          .step-connector { display: none !important; }
        }
      `}</style>
    </div>
  );
}

